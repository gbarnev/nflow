WORKFLOW "Your First AI Agent" active

CREDENTIAL @gemini = googlePalmApi "googlePalmApi Credential"

// ================================================================
// Trigger
// ================================================================

TRIGGER chat AS "Example Chat Window" {
  public: true,
  initialMessages: "Hi there! 👋",
  responseMode: "lastNode",
  title: "Your first AI Agent 🚀",
  subtitle: "This is for demo purposes. Try me out !"
}

// ================================================================
// AI Agent
// ================================================================

AGENT "Your First AI Agent" {
  systemMessage: "You are the n8n Demo AI Agent, a friendly and helpful assistant..."
}

// ================================================================
// LLM
// ================================================================

LLM gemini @gemini AS "Gemini" {
  model: "models/gemini-2.5-flash",
  temperature: 1
}

LLM openai AS "OpenAI" disabled {
  model: "gpt-4.1-mini",
  temperature: 1
}

// ================================================================
// Memory
// ================================================================

MEMORY buffer AS "Simple Memory" {
  contextWindowLength: 30
}

// ================================================================
// Tools
// ================================================================

TOOL http AS "get_a_joke" {
  url: "https://v2.jokeapi.dev/joke/Any?blacklistFlags=nsfw,religious,political,racist,sexist,explicit&type=single",
  description: "Gets a joke from the jokeapi.",
  optimizeResponse: true,
  fields: "joke"
}

TOOL datetime AS "days_from_now" {
  operation: "getTimeBetweenDates",
  description: "Gets the difference (in days) between now and a set date.",
  startDate: {{ $now }},
  endDate: {{ $fromAI('End_Date', 'The target date to calculate days until', 'string') }},
  outputFieldName: "now_day_difference"
}

TOOL wikipedia AS "wikipedia"

TOOL crypto AS "create_password" {
  action: "generate",
  description: "Generate a secure Password.",
  encodingType: "base64",
  stringLength: {{ $fromAI('Length', 'Usually 8 to 16 works well.', 'number') }}
}

TOOL code AS "calculate_loan_payment" {
  description: "Calculates the fixed monthly payment for a loan using the standard amortization formula.",
  schemaExample: '{"loan_amount": 250000, "annual_rate": 6.5, "term_years": 30}',
  code: ```
const principal = query.loan_amount;
const annualRate = query.annual_rate;
const years = query.term_years;
const monthlyRate = (annualRate / 100) / 12;
const numberOfPayments = years * 12;
if (principal <= 0 || annualRate <= 0 || years <= 0) {
  return { error: "Loan amount, interest rate, and term must be positive numbers." };
}
const monthlyPayment = principal * (monthlyRate * Math.pow(1 + monthlyRate, numberOfPayments)) / (Math.pow(1 + monthlyRate, numberOfPayments) - 1);
return JSON.stringify({
  monthly_payment: monthlyPayment.toFixed(2),
  total_paid: (monthlyPayment * numberOfPayments).toFixed(2),
  total_interest: ((monthlyPayment * numberOfPayments) - principal).toFixed(2)
});
```
}

TOOL rss AS "n8n_blog_rss_feed" {
  url: "https://n8n.io/blog/rss",
  description: "Gets the latest n8n blog posts."
}

// ================================================================
// Connections
// ================================================================

// Main flow
"Example Chat Window" -> "Your First AI Agent"

// AI connections (LLM, memory, tools -> agent)
"Gemini" -> LLM -> "Your First AI Agent"
"Simple Memory" -> MEMORY -> "Your First AI Agent"
"get_a_joke" -> TOOL -> "Your First AI Agent"
"days_from_now" -> TOOL -> "Your First AI Agent"
"wikipedia" -> TOOL -> "Your First AI Agent"
"create_password" -> TOOL -> "Your First AI Agent"
"calculate_loan_payment" -> TOOL -> "Your First AI Agent"
"n8n_blog_rss_feed" -> TOOL -> "Your First AI Agent"
